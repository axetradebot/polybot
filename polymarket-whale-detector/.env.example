# Polymarket — CLOB for order book / mid (public reads)
CLOB_API_URL=https://clob.polymarket.com
# Gamma — active markets
GAMMA_API_URL=https://gamma-api.polymarket.com
# Data API — global recent trades (no auth; CLOB /trades requires API keys)
DATA_API_URL=https://data-api.polymarket.com

# Telegram — WHALE ALERT BOT (separate from PolyBot's TELEGRAM_BOT_TOKEN)
WHALE_ALERT_BOT_TOKEN=
WHALE_ALERT_CHAT_ID=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Thresholds
WHALE_THRESHOLD_USD=5000
MEGA_WHALE_THRESHOLD_USD=25000
POLL_INTERVAL_SECONDS=30
INSIDER_SCORE_THRESHOLD=0.6
# Skip trades on markets resolving within this window (seconds, default 3600 = 1 hour)
IGNORE_NEAR_RESOLUTION_SECONDS=3600

# Optional: path to persist known MM / stats (defaults next to process)
# KNOWN_WALLETS_PATH=/home/ubuntu/polymarket-whale-detector/known_wallets.json
